{
  "name": "@benjilegnard/resum-tests",
  "version": "1.0.0",
  "description": "run end to end, accessibility and performance tests",
  "main": "index.js",
  "scripts": {
    "e2e-tests": "wdio run wdio.conf.ts",
    "api-tests": "artillery run",
    "prf-tests": "artillery run -o reports/artillery.io src/base.scenario.yml",
    "a11y": "echo \"run axe-reports\"",
    "lighthouse": "lighthouse --output-path ./reports/lighthouse-results.html https://www.benjaminlegrand.net",
    "start": "http-server reports/"
  },
  "author": "Benjamin Legrand",
  "license": "UNLICENSED",
  "dependencies": {
    "artillery": "^2.0.0-35",
    "axe": "^12.2.2",
    "http-server": "^14.1.1",
    "lighthouse": "^10.4.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^9.3.0",
    "@types/jest": "^29.5.3",
    "@types/node": "^18.0.0",
    "@wdio/cli": "^8.13.14",
    "@wdio/cucumber-framework": "^8.13.13",
    "@wdio/local-runner": "^8.13.13",
    "@wdio/spec-reporter": "^8.12.2",
    "chromedriver": "^115.0.0",
    "cucumber-html-reporter": "^7.1.1",
    "eslint": "^8.46.0",
    "jest": "^29.6.2",
    "ts-node": "^10.9.1",
    "typescript": "~5.0.4",
    "wdio-chromedriver-service": "^8.1.1",
    "webpack": "^5.88.2"
  }
}
